# ForgeLocal Commission Engine — environment template
# Copy to .env and fill in. NEVER commit .env. Keys come from env only — never hardcoded.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Stripe (cash events via webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=

# GoHighLevel (deal attribution)
GHL_API_KEY=
GHL_LOCATION_ID=

# Ramp (payouts) — banking details live in Ramp, not in our DB
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=
RAMP_API_TOKEN=
